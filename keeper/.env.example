# RPC endpoint for Base mainnet or Base Sepolia
RPC_URL=https://mainnet.base.org

# Private key of the keeper wallet (funded with ETH for gas)
KEEPER_PRIVATE_KEY=0x...

# BetRegistry contract address (from ShakeOnIt deployment)
BET_REGISTRY_ADDRESS=0x...

# The Graph subgraph URL (set after deploying the subgraph)
# Leave empty to fall back to on-chain event scanning
SUBGRAPH_URL=https://api.studio.thegraph.com/query/<id>/<slug>/version/latest

# Block number when BetRegistry was deployed (used by on-chain fallback to avoid scanning from block 0)
DEPLOY_BLOCK=0

# Set to "true" to simulate without sending transactions
DRY_RUN=false
